# This file includes environment variables for the Microsoft 365 Agents Playground.

# Built-in environment variables
TEAMSFX_ENV=playground

# Environment variables used by Microsoft 365 Agents Playground
TEAMSAPPTESTER_PORT=56150

# Azure OpenAI (OpenAI-compatible endpoint)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

COSMOS_ENDPOINT="https://your-cosmos-account.documents.azure.com:443/"
COSMOS_KEY="your-cosmos-db-primary-key"
COSMOS_DATABASE="raksha-db"

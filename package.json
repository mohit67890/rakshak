{
    "name": "rakshak",
    "version": "1.0.0",
    "description": "Rakshak — AI-powered POSH workplace-harassment reporting bot for Microsoft Teams. POSH Act 2013, Companies (Accounts) Rules 2025, and DPDPA 2023 compliant. Open source.",
    "keywords": [
        "posh",
        "posh-act",
        "posh-compliance",
        "workplace-harassment",
        "sexual-harassment",
        "internal-complaints-committee",
        "icc",
        "whistleblower",
        "vigil-mechanism",
        "grievance-redressal",
        "microsoft-teams",
        "teams-bot",
        "bot-framework",
        "azure-functions",
        "durable-functions",
        "azure-openai",
        "cosmos-db",
        "dpdpa",
        "india",
        "hr-tech",
        "companies-act",
        "typescript"
    ],
    "homepage": "https://github.com/mohit67890/rakshak#readme",
    "bugs": {
        "url": "https://github.com/mohit67890/rakshak/issues"
    },
    "author": "Mohit Garg <mohit@datapuls.ai>",
    "license": "MIT",
    "main": "./dist/index.js",
    "scripts": {
        "dev:teamsfx": "env-cmd --silent -f .localConfigs npm run dev",
        "dev:teamsfx:playground": "env-cmd --silent -f .localConfigs.playground npm run dev",
        "dev:teamsfx:launch-playground": "env-cmd --silent -f env/.env.playground agentsplayground start",
        "dev": "nodemon --exec node --inspect=9239 --signal SIGINT -r ts-node/register ./index.ts",
        "build": "cd tab && npm run build && cd .. && tsc --build",
        "build:tab": "cd tab && npm run build",
        "start": "node ./dist/index.js",
        "watch": "nodemon --exec \"npm run start\"",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mohit67890/rakshak.git"
    },
    "dependencies": {
        "@azure/cosmos": "^4.2.0",
        "@azure/identity": "^4.11.1",
        "@azure/storage-blob": "^12.26.0",
        "@microsoft/teams.apps": "^2.0.0",
        "@microsoft/teams.common": "^2.0.0",
        "openai": "^4.85.0",
        "uuid": "^11.1.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/uuid": "^10.0.0",
        "dotenv": "^17.4.2",
        "env-cmd": "^10.1.0",
        "nodemon": "^3.1.7",
        "sharp": "^0.34.5",
        "ts-node": "^10.4.0",
        "typescript": "~5.8.3",
        "vitest": "^4.1.4"
    }
}
